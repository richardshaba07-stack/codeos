{
  "name": "codeos",
  "displayName": "CodeOS",
  "description": "Sistema operativo per la comprensione del codice: grafo semantico vivo, contesto minimo per l'LLM e sistema immunitario architetturale live.",
  "version": "0.1.0",
  "license": "MIT",
  "publisher": "codeos",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "codeos.indexProject",
        "title": "CodeOS: Indicizza il progetto"
      },
      {
        "command": "codeos.indexFile",
        "title": "CodeOS: Indicizza il file attivo"
      },
      {
        "command": "codeos.query",
        "title": "CodeOS: Interroga il grafo (cosa cambia se tocco...?)"
      },
      {
        "command": "codeos.architectureReport",
        "title": "CodeOS: Referto architetturale (spazio negativo)"
      },
      {
        "command": "codeos.toggleWatch",
        "title": "CodeOS: Avvia/ferma il watch degli eventi"
      }
    ],
    "configuration": {
      "title": "CodeOS",
      "properties": {
        "codeos.serverAddress": {
          "type": "string",
          "default": "127.0.0.1:50051",
          "description": "Indirizzo host:porta del server gRPC di CodeOS (codeos-server)."
        },
        "codeos.autoConnect": {
          "type": "boolean",
          "default": true,
          "description": "Aprire automaticamente lo stream WatchEvents all'avvio, per ricevere live le violazioni architetturali."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "sync-proto": "node scripts/sync-proto.js",
    "compile": "npm run sync-proto && tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.0",
    "@grpc/proto-loader": "^0.7.10"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
